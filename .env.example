# =============================================================================
# Totus Environment Variables
# Copy this file to .env.local and fill in the values for local development.
# =============================================================================

# --- Database ---
# PostgreSQL connection string (local Docker Compose)
# See Docker Compose for local dev credentials
DATABASE_URL=postgresql://totus:totus@localhost:5432/totus

# --- Authentication ---
# Set to "true" to use the mock auth layer instead of real Clerk
NEXT_PUBLIC_USE_MOCK_AUTH=true

# HMAC secret for mock auth JWTs (only needed when NEXT_PUBLIC_USE_MOCK_AUTH=true)
MOCK_AUTH_SECRET=changeme

# --- Clerk Authentication (only needed when NEXT_PUBLIC_USE_MOCK_AUTH=false) ---
# Get these from https://dashboard.clerk.com
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Viewer Tokens ---
# HMAC secret for signing viewer session JWTs
VIEWER_JWT_SECRET=changeme

# Previous HMAC secret for viewer JWT rotation (can be same as above initially)
VIEWER_JWT_SECRET_PREVIOUS=changeme

# --- Encryption ---
# 32-byte hex-encoded key for local dev envelope encryption (AES-256-GCM)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Application ---
# Public-facing application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Oura API ---
# Oura OAuth2 client credentials (leave as placeholder for mock mode)
OURA_CLIENT_ID=your-oura-client-id
OURA_CLIENT_SECRET=your-oura-client-secret

# --- Observability ---
# Sentry DSN for error tracking (leave empty to disable)
SENTRY_DSN=
