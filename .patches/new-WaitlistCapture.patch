+"use client";
+
+import { useState } from "react";
+import { motion } from "framer-motion";
+import { ArrowRight, Check, Mail } from "lucide-react";
+import { Button } from "@/components/ui/button";
+
+const DEVICE_OPTIONS = [
+  "Oura Ring",
+  "Garmin",
+  "WHOOP",
+  "Apple Watch",
+  "Dexcom CGM",
+  "Withings",
+  "Cronometer",
+  "Other",
+];
+
+export function WaitlistCapture() {
+  const [email, setEmail] = useState("");
+  const [selectedDevices, setSelectedDevices] = useState<string[]>([]);
+  const [status, setStatus] = useState<"idle" | "loading" | "success" | "error">("idle");
+  const [errorMessage, setErrorMessage] = useState("");
+
+  function toggleDevice(device: string) {
+    setSelectedDevices((prev) =>
+      prev.includes(device)
+        ? prev.filter((d) => d !== device)
+        : [...prev, device],
+    );
+  }
+
+  async function handleSubmit(e: React.FormEvent) {
+    e.preventDefault();
+    if (!email.trim()) return;
+
+    setStatus("loading");
+    setErrorMessage("");
+
+    try {
+      const res = await fetch("/api/waitlist", {
+        method: "POST",
+        headers: { "Content-Type": "application/json" },
+        body: JSON.stringify({ email, devices: selectedDevices }),
+      });
+
+      if (!res.ok) {
+        const data = await res.json();
+        throw new Error(data.error || "Something went wrong");
+      }
+
+      setStatus("success");
+    } catch (err) {
+      setStatus("error");
+      setErrorMessage(
+        err instanceof Error ? err.message : "Something went wrong",
+      );
+    }
+  }
+
+  return (
+    <section className="px-4 py-16 md:py-20">
+      <motion.div
+        initial={{ opacity: 0, y: 30 }}
+        whileInView={{ opacity: 1, y: 0 }}
+        transition={{ duration: 0.6 }}
+        viewport={{ once: true }}
+        className="mx-auto max-w-2xl rounded-3xl border border-[var(--totus-mist)] bg-[var(--totus-cloud)] p-8 text-center md:p-12 dark:border-[#2a3a4a] dark:bg-[#0f1824]"
+      >
+        {status === "success" ? (
+          <div className="py-4">
+            <div className="mx-auto mb-4 flex size-12 items-center justify-center rounded-full bg-[var(--totus-emerald-tint)]">
+              <Check className="size-6 text-[var(--totus-emerald)]" />
+            </div>
+            <h3 className="mb-2 text-2xl font-bold">You&apos;re on the list</h3>
+            <p className="text-[var(--totus-slate)]">
+              We&apos;ll notify you when early access opens.
+            </p>
+          </div>
+        ) : (
+          <>
+            <div className="mx-auto mb-4 flex size-10 items-center justify-center rounded-full bg-[var(--totus-ocean-tint)]">
+              <Mail className="size-5 text-[var(--totus-ocean)]" />
+            </div>
+            <h3 className="mb-2 text-2xl font-bold md:text-3xl">
+              Get early access
+            </h3>
+            <p className="mb-8 text-[var(--totus-slate)]">
+              Free during early access. Join the waitlist and tell us which
+              devices you use.
+            </p>
+
+            <form onSubmit={handleSubmit} className="space-y-6">
+              {/* Device selection */}
+              <div>
+                <p className="mb-3 text-sm font-medium text-[var(--totus-ink)] dark:text-[var(--totus-cloud)]">
+                  Which devices do you use?
+                </p>
+                <div className="flex flex-wrap justify-center gap-2">
+                  {DEVICE_OPTIONS.map((device) => {
+                    const isSelected = selectedDevices.includes(device);
+                    return (
+                      <button
+                        key={device}
+                        type="button"
+                        onClick={() => toggleDevice(device)}
+                        className={`rounded-full border px-4 py-1.5 text-sm font-medium transition-colors ${
+                          isSelected
+                            ? "border-[var(--totus-ocean)] bg-[var(--totus-ocean)] text-white"
+                            : "border-[var(--totus-mist)] text-[var(--totus-slate)] hover:border-[var(--totus-ocean)] hover:text-[var(--totus-ocean)] dark:border-[#2a3a4a]"
+                        }`}
+                      >
+                        {device}
+                      </button>
+                    );
+                  })}
+                </div>
+              </div>
+
+              {/* Email input */}
+              <div className="mx-auto flex max-w-md gap-2">
+                <input
+                  type="email"
+                  required
+                  placeholder="you@example.com"
+                  value={email}
+                  onChange={(e) => setEmail(e.target.value)}
+                  className="flex-1 rounded-full border border-[var(--totus-mist)] bg-white px-5 py-3 text-sm outline-none transition-colors placeholder:text-[var(--totus-slate)]/50 focus:border-[var(--totus-ocean)] dark:border-[#2a3a4a] dark:bg-[#1f2433] dark:text-[var(--totus-cloud)]"
+                />
+                <Button
+                  type="submit"
+                  disabled={status === "loading"}
+                  className="rounded-full bg-[var(--totus-coral)] px-6 text-sm text-white hover:bg-[var(--totus-coral)]/90 disabled:opacity-50"
+                >
+                  {status === "loading" ? (
+                    "Joining..."
+                  ) : (
+                    <>
+                      Join waitlist
+                      <ArrowRight className="ml-1.5 size-4" />
+                    </>
+                  )}
+                </Button>
+              </div>
+
+              {status === "error" && (
+                <p className="text-sm text-[var(--totus-coral)]">
+                  {errorMessage}
+                </p>
+              )}
+            </form>
+          </>
+        )}
+      </motion.div>
+    </section>
+  );
+}
